{
  "name": "safepump-core",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "anchor build",
    "deploy:devnet": "solana program deploy --program-id target/deploy/safepump_core-keypair.json --url devnet --max-sign-attempts 20 --with-compute-unit-price 1000 target/deploy/safepump_core.so",
    "test": "anchor test --validator legacy",
    "test:devnet": "anchor test --skip-local-validator --skip-deploy --provider.cluster devnet",
    "test:ts": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "token:plan": "node mainnet-launch/scripts/plan-token-launch.mjs",
    "lint:fix": "prettier \"**/*{.js,.ts,md,json}\" -w",
    "lint": "prettier \"**/*{.js,.ts,md,json}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.6",
    "chai": "^4.3.10",
    "mocha": "^10.4.0",
    "prettier": "^3.3.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.5.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
